# APIs are exposed by every process. Enable exactly one scheduler group per
# process. All omitted ENABLE_* flags are false; keep UMS-test isolated.
PORT=5003
clientId=ums
CONFIG_URL=https://REPLACE_WITH_CONFIG_HOST/configuration
CONFIG_URLS=https://REPLACE_WITH_CONFIG_HOST/configuration
BUILD_URLS=https://REPLACE_WITH_CONFIG_HOST/builds

ENABLE_CMS_SCHEDULER=false
ENABLE_UMS_SCHEDULER=true
ENABLE_UMS_TEST_SCHEDULER=false
